# =============================================================================
# Lunerie · environment configuration
# Copy to `.env` and adjust. docker compose reads `.env` automatically.
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
POSTGRES_DB=lunerie
POSTGRES_USER=lunerie
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432

# Hikari connection pool sizing (per backend replica)
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_CONNECTION_TIMEOUT_MS=10000
DB_POOL_IDLE_TIMEOUT_MS=300000
DB_POOL_MAX_LIFETIME_MS=1800000
DB_POOL_LEAK_THRESHOLD_MS=30000

# -----------------------------------------------------------------------------
# Backend service (Spring Boot · stateless · scalable)
# -----------------------------------------------------------------------------
# Number of backend replicas behind the nginx load balancer.
# `docker compose up -d` honors this; can also override at runtime:
#     docker compose up -d --scale backend=3
BACKEND_REPLICAS=2

# Memory limits per replica (k8s-style)
BACKEND_MEM_LIMIT=768M
BACKEND_MEM_RESERVE=256M

# Build / image tag pushed by CI
IMAGE_TAG=latest

# Public port exposed by the nginx gateway (load balances backend replicas)
API_GATEWAY_PORT=8080

# -----------------------------------------------------------------------------
# JWT · MUST be at least 32 bytes; rotate periodically
# -----------------------------------------------------------------------------
LUNERIE_JWT_SECRET=please-replace-with-a-cryptographically-strong-32+byte-secret
LUNERIE_JWT_ISSUER=lunerie-api
LUNERIE_JWT_AUDIENCE=lunerie-app
LUNERIE_JWT_ACCESS_TTL=PT15M
LUNERIE_JWT_REFRESH_TTL=P30D
LUNERIE_JWT_MAX_REFRESH_PER_USER=8

# -----------------------------------------------------------------------------
# CORS · comma-separated origin list
# -----------------------------------------------------------------------------
LUNERIE_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4173

# -----------------------------------------------------------------------------
# Auth rate limiter (token bucket per IP, applied to /api/auth/*)
# -----------------------------------------------------------------------------
LUNERIE_RATE_CAPACITY=30
LUNERIE_RATE_REFILL=30
LUNERIE_RATE_REFILL_PERIOD=PT1M
LUNERIE_REFRESH_CLEANUP_CRON=0 0 * * * *

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_WEB=INFO
LOG_LEVEL_SQL=WARN

# -----------------------------------------------------------------------------
# Runtime (Java 21 virtual threads)
# -----------------------------------------------------------------------------
VIRTUAL_THREADS_ENABLED=true

# -----------------------------------------------------------------------------
# Observability ports (host-side)
# -----------------------------------------------------------------------------
LOKI_PORT=3100
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
TEMPO_PORT=3200
OTEL_HTTP_PORT=4318
OTEL_GRPC_PORT=4317
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-admin

# -----------------------------------------------------------------------------
# Distributed tracing (OpenTelemetry → OTel collector → Tempo)
# -----------------------------------------------------------------------------
LUNERIE_TRACING_ENABLED=true
# 1.0 = sample every request; lower in high-traffic prod (e.g. 0.1).
LUNERIE_TRACING_SAMPLE_RATE=1.0
LUNERIE_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
# W3C / B3 / B3_MULTI — keep W3C unless integrating with a legacy B3 system.
LUNERIE_TRACING_PROPAGATION=W3C
# Lands as the deployment.environment resource attribute on every span.
LUNERIE_ENV=docker
LUNERIE_INSTANCE_ID=backend

# -----------------------------------------------------------------------------
# Environment label for Prometheus external_labels
# -----------------------------------------------------------------------------
ENV=local

# -----------------------------------------------------------------------------
# Optional admin bootstrap (auto-creates admin user on startup if both set)
# -----------------------------------------------------------------------------
LUNERIE_ADMIN_EMAIL=
LUNERIE_ADMIN_PASSWORD=
LUNERIE_ADMIN_NAME=Lunerie Admin

# -----------------------------------------------------------------------------
# Pagination defaults
# -----------------------------------------------------------------------------
LUNERIE_DEFAULT_PAGE_SIZE=24
LUNERIE_MAX_PAGE_SIZE=100

# -----------------------------------------------------------------------------
# Slow request threshold (ms) — requests above are logged as WARN for Loki
# -----------------------------------------------------------------------------
LUNERIE_SLOW_REQ_THRESHOLD_MS=1500

# -----------------------------------------------------------------------------
# Adminer + MailHog (dev-only, gated behind --profile dev)
#   docker compose --profile dev up -d
# -----------------------------------------------------------------------------
ADMINER_PORT=8081
MAILHOG_HTTP_PORT=8025
MAILHOG_SMTP_PORT=1025

# -----------------------------------------------------------------------------
# SMTP — points at MailHog by default. In production, point at your real SMTP.
# -----------------------------------------------------------------------------
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false
LUNERIE_MAIL_FROM=no-reply@lunerie.local
LUNERIE_FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Cookie security — disable Secure in dev so cookies work over http://localhost
# -----------------------------------------------------------------------------
LUNERIE_COOKIE_SECURE=true
LUNERIE_COOKIE_SAME_SITE=Strict

# -----------------------------------------------------------------------------
# Alertmanager
# -----------------------------------------------------------------------------
ALERTMANAGER_PORT=9093

# -----------------------------------------------------------------------------
# Postgres backup schedule (cron-like)
# -----------------------------------------------------------------------------
POSTGRES_BACKUP_SCHEDULE=@daily
POSTGRES_BACKUP_KEEP_DAYS=14
POSTGRES_BACKUP_KEEP_WEEKS=8
POSTGRES_BACKUP_KEEP_MONTHS=6

# -----------------------------------------------------------------------------
# Trusted proxies (Tomcat) — Docker bridge ranges by default
# -----------------------------------------------------------------------------
LUNERIE_TRUSTED_PROXIES=127\.0\.0\.1|::1|172\.(?:1[6-9]|2[0-9]|3[01])\.\d+\.\d+|10\.\d+\.\d+\.\d+|192\.168\.\d+\.\d+
