# Copy to `.env.local` (Vite will pick it up automatically). NEVER commit `.env.local`.

# URL of the Lunerie backend API
VITE_LUNERIE_API_URL=http://localhost:8080

# Toggle live external APIs in the legacy externalContentService (kept for fallback)
VITE_NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
VITE_OVERPASS_BASE_URL=https://overpass-api.de/api
VITE_GEONAMES_BASE_URL=https://secure.geonames.org
VITE_REST_COUNTRIES_BASE_URL=https://restcountries.com/v3.1
