{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "type": "stat",
      "title": "API instances up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }, "unit": "none" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [ { "expr": "count(up{job=\"lunerie-backend\"} == 1)", "legendFormat": "instances" } ],
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "HTTP requests / sec (per instance)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum by(instance) (rate(http_server_requests_seconds_count[1m]))", "legendFormat": "{{instance}}" } ],
      "gridPos": { "h": 8, "w": 12, "x": 4, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "type": "timeseries",
      "title": "p95 latency (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "histogram_quantile(0.95, sum by(le, uri) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "{{uri}}" } ],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "JVM heap used",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum by(instance, area) (jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "{{instance}} {{area}}" } ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "type": "timeseries",
      "title": "Hikari active connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum by(instance) (hikaricp_connections_active)", "legendFormat": "{{instance}}" } ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "type": "logs",
      "title": "Backend logs (live)",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [ { "expr": "{compose_service=\"backend\"}", "refId": "A" } ],
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "enableLogDetails": true },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 16 }
    },
    {
      "type": "stat",
      "title": "Errors (5m)",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [ { "expr": "sum(count_over_time({compose_service=\"backend\", level=\"ERROR\"}[5m]))", "legendFormat": "errors" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 } ] } } },
      "options": { "colorMode": "background", "graphMode": "area" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 28 }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["lunerie"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Lunerie Overview",
  "uid": "lunerie-overview",
  "version": 1,
  "weekStart": ""
}
