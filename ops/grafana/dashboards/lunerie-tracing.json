{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Distributed tracing observability for Lunerie — traces from Tempo, span-derived latency from Prometheus, service graph and error rate.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "Trace pipeline health",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Traces ingested / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 5 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": { "unit": "ops", "decimals": 1 }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(otelcol_receiver_accepted_spans_total[1m]))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Traces refused / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 5 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.001, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(otelcol_receiver_refused_spans_total[1m]))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Tempo ingester active blocks",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 5 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(tempodb_blocklist_length)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Collector queue depth",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 5 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 100, "color": "yellow" },
              { "value": 1000, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(otelcol_exporter_queue_size)"
        }
      ]
    },
    {
      "type": "row",
      "title": "Span-derived latency (Tempo metrics_generator)",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "p95 latency by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{service}}",
          "expr": "histogram_quantile(0.95, sum by(le, service) (rate(traces_spanmetrics_duration_milliseconds_bucket[5m])))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request rate by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{service}}",
          "expr": "sum by(service) (rate(traces_spanmetrics_calls_total[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error-span rate by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{service}}",
          "expr": "sum by(service) (rate(traces_spanmetrics_calls_total{status_code=\"STATUS_CODE_ERROR\"}[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 latency by lunerie span name",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{span_name}}",
          "expr": "histogram_quantile(0.95, sum by(le, span_name) (rate(traces_spanmetrics_duration_milliseconds_bucket{span_name=~\"lunerie\\\\..+\"}[5m])))"
        }
      ]
    },
    {
      "type": "row",
      "title": "Search by trace id",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "traces",
      "title": "Recent traces (Tempo search)",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 12 },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceqlSearch",
          "filters": [
            {
              "id": "service",
              "operator": "=",
              "scope": "resource",
              "tag": "service.name",
              "value": ["lunerie-api"],
              "valueType": "string"
            }
          ],
          "limit": 50
        }
      ]
    }
  ],
  "preload": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["lunerie", "tracing", "tempo", "otel"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Lunerie · Tracing",
  "uid": "lunerie-tracing",
  "version": 1,
  "weekStart": ""
}
