{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["src/*"]
    },
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/App.tsx",
    "src/main.tsx",
    "src/index.css",
    "src/vite-env.d.ts",
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "src/api/**/*.ts",
    "src/api/**/*.tsx",
    "src/components/AppShell.tsx",
    "src/components/ErrorBoundary.tsx",
    "src/components/PlacesMap.tsx",
    "src/components/**/*.test.tsx",
    "src/config/**/*.ts",
    "src/constants/app.ts",
    "src/constants/categories.ts",
    "src/constants/locales.ts",
    "src/constants/queryKeys.ts",
    "src/constants/storage.ts",
    "src/data/mockPlaces.ts",
    "src/domain/**/*.ts",
    "src/errors/**/*.ts",
    "src/hooks/useCountries.ts",
    "src/hooks/useCountryPlaces.ts",
    "src/hooks/useExplorePlaces.ts",
    "src/hooks/useNearbyPlaces.ts",
    "src/hooks/usePlaceSearch.ts",
    "src/hooks/**/*.test.tsx",
    "src/i18n/I18nProvider.tsx",
    "src/i18n/messages.ts",
    "src/logging/**/*.ts",
    "src/screens/**/*.tsx",
    "src/services/serviceWorker.ts",
    "src/state/**/*.tsx",
    "src/storage/**/*.ts",
    "src/test/**/*.tsx",
    "src/theme/**/*.ts",
    "src/theme/**/*.tsx",
    "src/utils/datetime.ts",
    "src/utils/locale.ts",
    "vitest.setup.ts"
  ]
}
